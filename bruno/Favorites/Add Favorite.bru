meta {
  name: Add Favorite
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/addresses/:addressId/favorite
  body: none
  auth: none
}

params:path {
  addressId: 1
}

headers {
  cookie: token={{token}}
}

assert {
  res.status: eq 200
  res.body.item.isFavorite: eq true
}

tests {
  test("should mark address as favorite", function() {
    expect(res.status).to.equal(200);
    expect(res.body.item).to.have.property('isFavorite');
    expect(res.body.item.isFavorite).to.equal(true);
  });
}
